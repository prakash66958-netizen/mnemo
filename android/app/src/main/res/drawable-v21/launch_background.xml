<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash for API 21+: use the system window background (follows
     light/dark) with the brand bolt centered on top for visual continuity
     with the in-app splash in lib/app.dart. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="?android:colorBackground" />
    <item
        android:drawable="@drawable/splash_bolt"
        android:gravity="center" />
</layer-list>
