<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher icon background.

    Brand indigo `#4F46E5` (matches AppTheme._seed in
    lib/core/theme/app_theme.dart) with a subtle linear gradient from a
    slightly lighter indigo at the top-left to a deeper indigo at the
    bottom-right. The gradient is shallow enough that the background reads
    as a solid brand colour on a launcher grid but still has some depth.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:startColor="#6366F1"
                android:endColor="#4338CA" />
        </aapt:attr>
    </path>
</vector>
